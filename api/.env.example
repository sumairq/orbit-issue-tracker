# Copy this file to `api/.env` and fill in your own values.
# These are placeholders — never commit real secrets.

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=orbit_development

# Secret used to sign JWT auth tokens (use a long random string)
JWT_SECRET=replace-with-a-long-random-string

# Port the API listens on
PORT=3000
